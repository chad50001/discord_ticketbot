# Discord Ticket Bot
# Copy this file to .env and fill in your values

# Your Discord bot token (from https://discord.com/developers/applications)
TOKEN="YOUR_BOT_TOKEN_HERE"

# Your Discord application/client ID
CLIENT_ID="YOUR_CLIENT_ID_HERE"

# Your Discord server (guild) ID
GUILD_ID="YOUR_GUILD_ID_HERE"

# ── MSK Transcript Service ────────────────────────────────────────────────────
# API key from msk-scripts.de – required for transcript links.
# Get yours at: https://msk-scripts.de/verify
MSK_API_KEY="YOUR_MSK_API_KEY_HERE"

# Base URL of the MSK API (do not change unless self-hosting the website)
MSK_API_URL="https://www.msk-scripts.de"
